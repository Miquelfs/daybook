# Daybook environment variables
# Copy this file to .env and fill in your values.
# Never commit .env to git.

# ── Garmin ────────────────────────────────────────────────────────────────────
# Only needed if data/raw/garmin_session/ is empty (first login).
# Once the tokenstore is populated, these are not used.
GARMIN_EMAIL=you@example.com
GARMIN_PASSWORD=yourpassword

# ── Timezone ──────────────────────────────────────────────────────────────────
# Used by the API and web app for "today" calculations.
TZ=Europe/Madrid

# ── API ───────────────────────────────────────────────────────────────────────
API_HOST=127.0.0.1
API_PORT=8000

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for the API.
# On Pi: add the Tailscale IP of the Pi, e.g.:
#   CORS_ORIGINS=http://localhost:3000,http://100.x.x.x:3000
CORS_ORIGINS=http://localhost:3000

# ── Frontend ──────────────────────────────────────────────────────────────────
# URL the browser uses to reach the API. Set to Pi's Tailscale IP on Pi.
# On Mac (dev): leave as http://localhost:8000
# On Pi (prod): http://<pi-tailscale-ip>:8000
NEXT_PUBLIC_API_URL=http://localhost:8000
